{
  "name": "astrodigest",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "typecheck": "turbo run typecheck",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "turbo": "latest",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  },
  "packageManager": "npm@10.9.2",
  "lint-staged": {
    "**/*.{ts,tsx}": "eslint --fix",
    "**/*.{ts,tsx,js,jsx,json,md}": "prettier --write"
  }
}
