{
  "name": "@astrodigest/database",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,js,json}\"",
    "typecheck": "tsc --noEmit",
    "migrate": "node-pg-migrate up --database-url-var NEON_DATABASE_URL",
    "migrate:rollback": "node scripts/rollback.mjs",
    "migrate:create": "node-pg-migrate create"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.20.0"
  }
}
