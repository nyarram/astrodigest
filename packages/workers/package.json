  "scripts": {
    "dev": "tsx --env-file=../../.env src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,js,json}\"",
    "test:pipeline": "tsx --env-file=../../.env src/test-pipeline.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@astrodigest/database": "*",
    "@neondatabase/serverless": "^0.10.4",
    "@upstash/redis": "^1.34.3",
    "bullmq": "^5.40.0",
    "dotenv": "^16.4.7",
    "groq-sdk": "^1.1.2",
    "ioredis": "^5.4.2",
    "pino": "^9.6.0"
  },
  "devDependencies": {
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2"
