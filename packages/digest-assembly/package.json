{
  "name": "@astrodigest/digest-assembly",
  "version": "0.0.1",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "dev": "tsx --env-file=../../.env src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,js,json}\""
  },
  "dependencies": {
    "@astrodigest/database": "*",
    "@astrodigest/shared": "*",
    "@upstash/redis": "^1.34.3",
    "bullmq": "^5.40.0",
    "ioredis": "^5.4.2",
    "pino": "^9.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2"
  }
}
