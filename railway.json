{
  "$schema": "https://railway.app/railway-schema.json",
  "services": {
    "api": {
      "build": {
        "builder": "NIXPACKS",
        "buildCommand": "npm run build --workspace=@astrodigest/api"
      },
      "deploy": {
        "startCommand": "npm run start --workspace=@astrodigest/api",
        "healthcheckPath": "/health",
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 3
      }
    },
    "digest-assembly": {
      "build": {
        "builder": "NIXPACKS",
        "buildCommand": "npm run build --workspace=@astrodigest/digest-assembly"
      },
      "deploy": {
        "startCommand": "node packages/digest-assembly/dist/index.js",
        "cronSchedule": "0 20 * * 5"
      }
    }
  }
}
